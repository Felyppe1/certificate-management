datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client"
    output   = "client"
}

enum COLUMN_TYPE {
    STRING
    NUMBER
    BOOLEAN
    DATE
    ARRAY
}

enum ARRAY_ITEM_TYPE {
    STRING
    NUMBER
    BOOLEAN
    DATE
}

model User {
    id            String  @id @default(cuid())
    email         String  @unique
    name          String
    password_hash String?
    credits       Int     @default(300)

    Session             Session[]
    ExternalUserAccount ExternalUserAccount[]

    CertificateEmission CertificateEmission[]
    DailyUsage          DailyUsage[]

    @@map("users")
}

model Session {
    token      String   @id
    user_id    String
    expires_at DateTime

    User User @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@map("sessions")
}

model ExternalUserAccount {
    user_id          String
    provider         String // "GOOGLE" | "GITHUB" | "FACEBOOK" | ...
    provider_user_id String

    access_token                  String
    refresh_token                 String?
    access_token_expiry_datetime  DateTime?
    refresh_token_expiry_datetime DateTime?

    User User @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@id([user_id, provider])
    @@unique([provider, provider_user_id])
    @@map("external_user_accounts")
}

model CertificateEmission {
    id         String   @id @default(cuid())
    title      String
    status     String // "DRAFT" | "EMITTED" | "SCHEDULED"
    created_at DateTime @default(now())

    user_id String

    User                         User                           @relation(fields: [user_id], references: [id], onDelete: Cascade)
    Template                     Template?
    DataSource                   DataSource?
    Email                        Email?

    @@map("certificate_emissions")
}

model Template {
    certificate_emission_id String @id

    drive_file_id    String?
    storage_file_url String?
    thumbnail_url    String?
    file_name        String
    input_method     String // "URL" | "GOOGLE_DRIVE" | "UPLOAD"
    file_extension   String

    TemplateVariable    TemplateVariable[]
    CertificateEmission CertificateEmission @relation(fields: [certificate_emission_id], references: [id], onDelete: Cascade)

    @@map("templates")
}

model TemplateVariable {
    template_id String
    name        String

    data_source_id   String?
    data_source_name String?

    Template         Template          @relation(fields: [template_id], references: [certificate_emission_id], onDelete: Cascade)
    DataSourceColumn DataSourceColumn? @relation(fields: [data_source_id, data_source_name], references: [data_source_id, name], onDelete: SetNull)

    @@id([name, template_id])
    @@unique([data_source_id, data_source_name])
    @@map("template_variables")
}

model DataSource {
    certificate_emission_id String @id

    thumbnail_url  String?
    input_method   String // "URL" | "GOOGLE_DRIVE" | "UPLOAD"
    file_extension String

    DataSourceColumn    DataSourceColumn[]
    DataSourceRow       DataSourceRow[]
    DataSourceFile      DataSourceFile[]
    CertificateEmission CertificateEmission @relation(fields: [certificate_emission_id], references: [id], onDelete: Cascade)

    @@map("data_sources")
}

model DataSourceFile {
    data_source_id   String
    file_index       Int
    file_name        String
    drive_file_id    String?
    storage_file_url String?

    DataSource DataSource @relation(fields: [data_source_id], references: [certificate_emission_id], onDelete: Cascade)

    @@id([data_source_id, file_index])
    @@map("data_source_files")
}

model DataSourceColumn {
    data_source_id  String
    name            String
    type            COLUMN_TYPE
    array_separator String?
    array_item_type ARRAY_ITEM_TYPE?

    DataSource       DataSource        @relation(fields: [data_source_id], references: [certificate_emission_id], onDelete: Cascade)
    TemplateVariable TemplateVariable?
    DataSourceValue  DataSourceValue[]
    Email Email?

    @@id([name, data_source_id])
    @@map("data_source_columns")
}

model DataSourceValue {
    data_source_id     String
    column_name        String
    data_source_row_id String
    value              String

    DataSourceColumn DataSourceColumn @relation(fields: [data_source_id, column_name], references: [data_source_id, name], onDelete: Cascade)
    DataSourceRow    DataSourceRow    @relation(fields: [data_source_id, data_source_row_id], references: [data_source_id, id], onDelete: Cascade)

    @@id([data_source_id, column_name, data_source_row_id])
    @@map("data_source_values")
}

model DataSourceRow {
    id                String   @id @default(cuid())
    data_source_id    String
    file_bytes        Int?
    processing_status String // "PENDING" | "RUNNING" | "RETRYING" | "COMPLETED" | "FAILED"
    source_row_index  Int
    created_at        DateTime @default(now())

    DataSourceValue DataSourceValue[]

    DataSource DataSource @relation(fields: [data_source_id], references: [certificate_emission_id], onDelete: Cascade)

    @@unique([id, data_source_id])
    @@map("data_source_rows")
}

model Email {
    id               String    @id @default(cuid())
    certificate_emission_id String  @unique
    subject          String
    body             String
    email_column            String
    scheduled_at     DateTime?
    status           String // "PENDING" | "RUNNING" | "COMPLETED" | "FAILED"
    email_error_type String?

    CertificateEmission    CertificateEmission      @relation(fields: [certificate_emission_id], references: [id], onDelete: Cascade)
    DataSourceColumn        DataSourceColumn   @relation(fields: [email_column, certificate_emission_id], references: [name, data_source_id])

    @@unique([email_column, certificate_emission_id])
    @@map("emails")
}

model DailyUsage {
    user_id                      String
    date                         DateTime @db.Date
    certificates_generated_count Int
    emails_sent_count            Int

    User User @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@id([user_id, date])
    @@map("daily_usages")
}

model Outbox {
    id         String   @id @default(cuid())
    event_type String
    payload    Json
    processed  Boolean  @default(false)
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    @@map("outbox")
}
